---

<section id="carta" class="py-24 bg-olive-50/50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="text-olive-500 text-sm font-medium tracking-widest uppercase">Nuestra carta</span>
      <h2 class="font-heading text-4xl sm:text-5xl font-bold text-olive-900 mt-2">
        El sabor de la tosta
      </h2>
      <p class="text-olive-600/70 mt-4 max-w-2xl mx-auto">
        Todas nuestras tostas estan elaboradas con pan 100% masa madre,
        aceite de oliva virgen extra y los mejores ingredientes frescos.
      </p>
    </div>

    <div class="space-y-16">
      {categories.map((category) => (
        <div>
          <div class="mb-8 pb-4 border-b border-olive-200">
            <h3 class="font-heading text-3xl font-bold text-olive-800">{category.name}</h3>
            <p class="text-olive-500 text-sm mt-1">{category.description}</p>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-4">
            {category.items.map((item) => (
              <div class="flex items-baseline justify-between py-2 group">
                <div class="flex-1 min-w-0 pr-4">
                  <span class="font-heading text-lg font-semibold text-olive-800 group-hover:text-olive-600 transition-colors">
                    {item.name}
                  </span>
                  <span class="block text-sm text-olive-500 truncate">{item.desc}</span>
                </div>
                <span class="font-heading text-lg font-bold text-olive-600 shrink-0">
                  {item.price}&euro;
                </span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 text-center">
      <div class="inline-flex items-center gap-3 bg-white rounded-2xl px-8 py-4 shadow-sm border border-olive-100">
        <svg class="w-5 h-5 text-olive-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <p class="text-sm text-olive-600">
          Consulta alergenos e intolerancias con nuestro personal. Opciones veganas y vegetarianas disponibles.
        </p>
      </div>
    </div>
  </div>
</section>
