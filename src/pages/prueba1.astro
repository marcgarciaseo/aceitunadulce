    <style is:global>
      .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
      .scrollbar-hide::-webkit-scrollbar { display: none; }

      /* Marquee */
      .marquee-track { display: flex; overflow: hidden; }
      .marquee-content {
        display: flex; align-items: center;
        animation: marqueeScroll 25s linear infinite;
        white-space: nowrap;
      }
      @keyframes marqueeScroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

      .marquee-track-reverse { display: flex; overflow: hidden; }
      .marquee-content-reverse {
        display: flex; align-items: center;
        animation: marqueeScrollReverse 35s linear infinite;
        white-space: nowrap;
      }
      @keyframes marqueeScrollReverse { 0% { transform: translateX(-50%); } 100% { transform: translateX(0); } }

      /* Nav active */
      .hero-nav-btn.active { background: rgba(154, 170, 111, 0.5); border-color: rgba(154, 170, 111, 0.6); }

      /* Smooth scroll */
      html { scroll-behavior: smooth; }

      /* Border-3 utility */
      .border-3 { border-width: 3px; }
      .border-t-3 { border-top-width: 3px; }
      .border-b-3 { border-bottom-width: 3px; }
    </style>


    <!-- ===== SCRIPTS ===== -->
    <script>
      const sections = document.querySelectorAll('.hero-section');
      const navBtns = document.querySelectorAll('.hero-nav-btn');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const num = entry.target.id.replace('hero', '');
            navBtns.forEach(btn => {
              btn.classList.toggle('active', btn.dataset.hero === num);
            });
          }
        });
      }, { threshold: 0.3 });
      sections.forEach(section => observer.observe(section));
    </script>

